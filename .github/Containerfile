# Signature: emFta2FyYQ==
ARG VARIANT=ark

# Final Image (ark linux)
FROM docker.io/archlinux:latest
ARG VARIANT

LABEL ostree.bootable="true"
LABEL containers.bootc="1"

# Layer 1: Base system packages (no kernel — variant-independent)
RUN set -e; \
    sed -i '/NoExtract/d' /etc/pacman.conf && \
    printf '\n[multilib]\nInclude = /etc/pacman.d/mirrorlist\n' >> /etc/pacman.conf; \
    pacman -Syu --noconfirm; \
    pacman -S --noconfirm \
        base base-devel glibc linux-firmware networkmanager mkinitcpio \
        gnome-shell gnome-control-center gnome-keyring gnome-session gnome-settings-daemon \
        nautilus xdg-desktop-portal-gnome xdg-user-dirs-gtk gnome-console gdm gnome-software \
        flatpak gnome-initial-setup \
        webp-pixbuf-loader libheif libavif libraw ffmpegthumbnailer poppler-glib libgsf \
        util-linux openssl efibootmgr dosfstools e2fsprogs xfsprogs ostree skopeo \
        btrfs-progs podman composefs ibus iso-codes shadow sudo git nano zsh fish; \
    sed -i 's/^#\(.*UTF-8.*\)/\1/' /etc/locale.gen; \
    echo "LANG=en_US.UTF-8" > /etc/locale.conf; \
    ln -sf /usr/share/zoneinfo/UTC /etc/localtime; \
    chmod u+s /usr/bin/newuidmap /usr/bin/newgidmap; \
    pacman -Scc --noconfirm

# Layer 2: OSTree sysroot + systemd services
RUN systemctl enable gdm NetworkManager && \
    systemctl mask systemd-firstboot.service && \
    mkdir -p /etc/ostree && \
    printf "[sysroot]\ncomposefs=false\n" > /etc/ostree/prepare-root.conf && \
    mkdir -p /sysroot /sysroot/ostree /.snapshots && \
    ln -sfn sysroot/ostree /ostree && \
    glib-compile-schemas /usr/share/glib-2.0/schemas/

# Layer 3: bootupd + home/root symlinks
RUN [ -f /usr/libexec/bootupd ] && chmod +x /usr/libexec/bootupd /usr/bin/bootupctl || true; \
    rm -rf /home /root && \
    ln -sf var/home /home && \
    ln -sf var/roothome /root

# Layer 4: Prepare /var/nix (nix subvolume target; nix itself installed in Layer 11 from AUR)
RUN mkdir -p /var/nix

# Layer 5: BLS sync
COPY bls-sync.sh /usr/libexec/ark/bls-sync.sh
COPY bls-sync.conf /usr/lib/systemd/system/ostree-finalize-staged.service.d/bls-sync.conf
COPY bls-sync.conf /usr/lib/systemd/system/bootc-finalize-staged.service.d/bls-sync.conf
COPY ark-bls-sync.service /usr/lib/systemd/system/ark-bls-sync.service
RUN chmod +x /usr/libexec/ark/bls-sync.sh && \
    systemctl enable ark-bls-sync.service

# Layer 6: Orundum (container storage subvolume)
COPY ark-orundum.conf /usr/lib/tmpfiles.d/ark-orundum.conf
RUN mkdir -p /orundum /etc/skel/.local/share && \
    ln -sfn /orundum/containers /etc/skel/.local/share/containers

# Layer 7: Hostname sync
COPY ark-hostname-sync.sh /usr/lib/ark/ark-hostname-sync
COPY ark-hostname-sync.service /usr/lib/systemd/system/ark-hostname-sync.service
COPY ark-hostname-sync.path /usr/lib/systemd/system/ark-hostname-sync.path
RUN chmod +x /usr/lib/ark/ark-hostname-sync && \
    systemctl enable ark-hostname-sync.path

# Layer 8: carrier + PM symlinks + ark-home
RUN curl -sL "https://github.com/zamkara/carrier-pkg/releases/latest/download/carrier" \
    -o /usr/lib/ark/carrier && \
    chmod +x /usr/lib/ark/carrier
COPY ark-home.conf /usr/lib/tmpfiles.d/ark-home.conf
RUN ln -sf /usr/lib/ark/carrier /usr/local/bin/pacman && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/apt-get && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/apt && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/dnf && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/yum && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/zypper && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/apk && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/emerge && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/xbps-install && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/slackpkg && \
    ln -sf /usr/lib/ark/carrier /usr/local/bin/opkg

# Layer 9: Alga wrapper + desktop entry + D-Bus + update timer
COPY alga-wrapper.sh /usr/lib/ark/alga-wrapper
COPY com.zamkara.alga.desktop /usr/share/applications/com.zamkara.alga.desktop
COPY com.zamkara.alga.service /usr/share/dbus-1/services/com.zamkara.alga.service
COPY alga-update.service /usr/lib/systemd/system/alga-update.service
COPY alga-update.timer /usr/lib/systemd/system/alga-update.timer
RUN chmod +x /usr/lib/ark/alga-wrapper && \
    systemctl enable alga-update.timer

# Layer 10: /usr/local → /var/usrlocal symlink
RUN rm -rf /usr/local && ln -sf /var/usrlocal /usr/local

# Layer 11: Kernel + AUR packages + DKMS (variant-specific)
ARG AUR_SHA=unknown
RUN --mount=type=bind,source=aur-packages,target=/tmp/aur-packages \
    set -e; \
    echo "AUR SHA: ${AUR_SHA}"; \
    KERNEL="linux"; \
    CACHY_KERNEL=""; \
    if [[ "$VARIANT" == *"-apex"* ]]; then \
        CACHY_KERNEL="linux-cachyos"; \
        if [[ "$VARIANT" == *"-bore"* ]]; then CACHY_KERNEL="linux-cachyos-bore"; fi; \
        if [[ "$VARIANT" == *"-lts"* ]]; then CACHY_KERNEL="linux-cachyos-lts"; fi; \
        if [[ "$VARIANT" == *"-hardened"* ]]; then CACHY_KERNEL="linux-cachyos-hardened"; fi; \
        printf '\n[cachyos]\nSigLevel = Never\nServer = https://mirror.cachyos.org/repo/$arch/$repo\n' >> /etc/pacman.conf; \
        pacman-key --init; \
        pacman -Sy --noconfirm cachyos-keyring; \
        pacman-key --populate cachyos; \
        sed -i '/SigLevel = Never/d' /etc/pacman.conf; \
        pacman -Sy --noconfirm; \
        pacman -S --noconfirm $CACHY_KERNEL ${CACHY_KERNEL}-headers; \
    else \
        if [[ "$VARIANT" == *"-zen"* ]]; then KERNEL="linux-zen"; fi; \
        if [[ "$VARIANT" == *"-lts"* ]]; then KERNEL="linux-lts"; fi; \
        if [[ "$VARIANT" == *"-hardened"* ]]; then KERNEL="linux-hardened"; fi; \
        pacman -S --noconfirm $KERNEL; \
        pacman -U --noconfirm /tmp/aur-packages/${KERNEL}-headers-*.pkg.tar.zst 2>/dev/null || true; \
    fi; \
    _pkgs=$(ls /tmp/aur-packages/*.pkg.tar.zst 2>/dev/null | grep -vE '/(linux|linux-zen|linux-lts|linux-hardened)-headers-[0-9]' | tr '\n' ' '); \
    [ -n "$_pkgs" ] && pacman -U --noconfirm --overwrite '*' $_pkgs || true; \
    locale-gen; \
    KVER=$(ls -1 /usr/lib/modules | grep -v extramodules | head -n1); \
    dkms autoinstall -k "$KVER" 2>/dev/null || true; \
    pacman -Scc --noconfirm; \
    rm -f /var/usrlocal/bin/pacman; \
    systemd-sysusers; \
    mkdir -p /nix/var /etc/nix; \
    rm -rf /nix/var/nix; \
    ln -sf /var/nix /nix/var/nix; \
    echo "experimental-features = nix-command flakes" >> /etc/nix/nix.conf; \
    echo "trusted-users = root @wheel" >> /etc/nix/nix.conf; \
    echo "extra-nix-path = nixpkgs=channel:nixpkgs-unstable" >> /etc/nix/nix.conf; \
    systemctl enable nix-daemon.socket nix-daemon.service || true

# Layer 12: Nvidia (variant-specific, must be before mkinitcpio)
RUN set -e; \
    if [[ "$VARIANT" == *"-nvidia"* ]]; then \
        pacman -S --noconfirm steam lib32-nvidia-utils nvtop; \
        if [[ "$VARIANT" == *"-apex"* ]]; then \
            CACHY_KERNEL="linux-cachyos"; \
            if [[ "$VARIANT" == *"-bore"* ]]; then CACHY_KERNEL="linux-cachyos-bore"; fi; \
            if [[ "$VARIANT" == *"-lts"* ]]; then CACHY_KERNEL="linux-cachyos-lts"; fi; \
            if [[ "$VARIANT" == *"-hardened"* ]]; then CACHY_KERNEL="linux-cachyos-hardened"; fi; \
            pacman -S --noconfirm ${CACHY_KERNEL}-nvidia-open nvidia-utils nvidia-settings; \
        else \
            KERNEL="linux"; \
            if [[ "$VARIANT" == *"-zen"* ]]; then KERNEL="linux-zen"; fi; \
            if [[ "$VARIANT" == *"-lts"* ]]; then KERNEL="linux-lts"; fi; \
            if [[ "$VARIANT" == *"-hardened"* ]]; then KERNEL="linux-hardened"; fi; \
            if [ "$KERNEL" = "linux" ]; then \
                pacman -S --noconfirm nvidia-open nvidia-utils nvidia-settings; \
            else \
                pacman -S --noconfirm nvidia-open-dkms ${KERNEL}-headers dkms nvidia-utils nvidia-settings; \
            fi; \
        fi; \
        pacman -Scc --noconfirm; \
    fi

# Layer 13: mkinitcpio + initramfs cleanup
RUN set -e; \
    sed -i 's/^MODULES=.*/MODULES=(btrfs vfat ext4 xfs erofs overlay loop)/g' /etc/mkinitcpio.conf && \
    sed -i 's/^HOOKS=.*/HOOKS=(base systemd microcode modconf kms keyboard sd-vconsole block sd-encrypt plymouth ostree filesystems fsck)/g' /etc/mkinitcpio.conf && \
    mkinitcpio -P && \
    KVER=$(ls -1 /usr/lib/modules | grep -v 'extramodules' | head -n 1) && \
    IMG=$(ls -1 /boot/initramfs-*.img | grep -v 'fallback' | head -n 1) && \
    cp $IMG /usr/lib/modules/$KVER/initramfs.img && \
    rm -rf /boot/* /var/lib/pacman/sync/* /var/log/* /tmp/* /usr/share/doc/* /usr/share/man/* /usr/share/info/*

# Layer 14: Remove pacman + cleanup unwanted desktop entries
RUN rm -rf \
        /usr/bin/pacman* \
        /usr/bin/makepkg* \
        /usr/bin/repo-add \
        /usr/bin/repo-elephant \
        /usr/bin/repo-remove \
        /usr/bin/testpkg \
        /usr/bin/vercmp \
        /usr/lib/libalpm.so* \
        /usr/include/alpm* \
        /usr/lib/pkgconfig/libalpm.pc \
        /usr/lib/sysusers.d/alpm.conf \
        /usr/lib/systemd/system/sockets.target.wants/dirmngr@etc-pacman.d-gnupg.socket \
        /usr/lib/systemd/system/sockets.target.wants/gpg-agent*@etc-pacman.d-gnupg.socket \
        /usr/lib/systemd/system/sockets.target.wants/keyboxd@etc-pacman.d-gnupg.socket \
        /usr/share/bash-completion/completions/pacman* \
        /usr/share/bash-completion/completions/makepkg* \
        /usr/share/zsh/site-functions/_pacman* \
        /usr/share/man/man8/pacman* \
        /usr/share/man/man8/makepkg* \
        /usr/share/man/man8/repo-* \
        /usr/share/man/man8/vercmp* \
        /usr/share/man/man8/testpkg* \
        /etc/pacman.conf \
        /etc/pacman.d/ \
        /var/lib/pacman/ && \
    rm -f /usr/share/applications/{bssh,bvnc,avahi-discover,qv4l2,qvidcap,stoken-gui,stoken-gui-small,org.gnome.Extensions,org.gnome.TextEditor,lstopo,hwloc-ls,org.gnome.Logs,ibus,ibus-setup,ibus-wayland,scrcpy,scrcpy-console,veracrypt,timeshift,timeshift-gtk,org.freedesktop.MalcontentControl,nvtop}.desktop 2>/dev/null || true
