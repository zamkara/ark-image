#!/bin/bash
[ "$PAM_TYPE" = "open_session" ] || exit 0

HOME_DIR=$(getent passwd "$PAM_USER" 2>/dev/null | cut -d: -f6)
[ -n "$HOME_DIR" ] || exit 0
[ -d "$HOME_DIR" ] || exit 0

USER_UID=$(id -u "$PAM_USER" 2>/dev/null)
[ -n "$USER_UID" ] && [ "$USER_UID" -ge 1000 ] || exit 0

for dir in applications fonts icons themes backgrounds sounds; do
    source="/var/share/$dir"
    [ -d "$source" ] || continue
    target="$HOME_DIR/.local/share/$dir"
    mountpoint -q "$target" 2>/dev/null && continue
    [ -L "$target" ] && rm -f "$target"
    mkdir -p "$target"
    mount --bind "$source" "$target"
done
